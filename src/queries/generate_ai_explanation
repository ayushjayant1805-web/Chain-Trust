CREATE OR REPLACE QUERY generate_ai_explanation(STRING wallet_id) FOR GRAPH ChainTrustGraph SYNTAX v2 {
  SumAccum<INT> @@total_tx_count;
  SumAccum<INT> @@flagged_connections;
  MaxAccum<STRING> @@risk_level; 

  VERTEX target_wallet = to_vertex(wallet_id, "Wallet");
  Start = {target_wallet};

  // 1. Get base risk
  AnalyzeNode = SELECT w FROM Start:w POST-ACCUM @@risk_level += w.risk_level;

  // 2. Tally up connections
  Connections = SELECT t FROM Start:s -(_>:e)- Wallet:t
                WHERE type(e) == "TRANSACTION"
                ACCUM 
                  @@total_tx_count += 1,
                  IF t.risk_level == "CRITICAL" OR t.risk_level == "HIGH" OR t.risk_level == "Critical Risk" OR t.risk_level == "High Risk" THEN
                     @@flagged_connections += 1
                  END;

  // 3. Calculate ratio
  INT risk_ratio = 0;
  IF @@total_tx_count > 0 THEN
      risk_ratio = (@@flagged_connections * 100) / @@total_tx_count;
  END;

  // 4. Print the raw data payload for the LLM prompt
  PRINT @@risk_level AS base_risk, @@total_tx_count AS total_txs, @@flagged_connections AS flagged_txs, risk_ratio;
}