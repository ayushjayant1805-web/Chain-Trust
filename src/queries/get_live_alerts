CREATE OR REPLACE QUERY get_live_alerts() FOR GRAPH ChainTrustGraph SYNTAX v2 {
  TYPEDEF TUPLE <INT id, STRING severity, STRING timestamp, STRING title, STRING description, STRING pattern, BOOL isNew> AlertTuple;
  ListAccum<AlertTuple> @@alerts_list;
  
  // Traverse the graph to find high-risk wallets making transactions
  RecentTxs = SELECT s FROM Wallet:s -(_>:e)- Wallet:t
              WHERE type(e) == "TRANSACTION" 
              AND (s.risk_level == "CRITICAL" OR s.risk_level == "HIGH")
              
              // FIX 1: Use POST-ACCUM instead of ACCUM so we only get ONE alert per wallet
              POST-ACCUM @@alerts_list += AlertTuple(
                
                // FIX 2: Use a stable ID so the React dismissal logic works across 15s polls
                getvid(s), 
                
                s.risk_level, 
                "Recently", 
                
                CASE 
                  WHEN s.risk_level == "CRITICAL" THEN "Mixer Interaction Detected" 
                  ELSE "Wash Trading Suspected" 
                END, 
                
                CASE 
                  WHEN s.risk_level == "CRITICAL" THEN "Wallet " + s.short_address + " engaged in critical high-risk mixer transfers." 
                  ELSE "Wallet " + s.short_address + " is exhibiting suspicious wash trading loops." 
                END, 
                
                CASE WHEN s.risk_level == "CRITICAL" THEN "MIXER" ELSE "WASH_TRADE" END, 
                true
              )
              LIMIT 12;
              
  PRINT @@alerts_list AS Alerts;
}